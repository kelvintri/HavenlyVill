<?xml version="1.0" encoding="UTF-8" ?>
<phpdocumentor
    configVersion="3"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xmlns="https://www.phpdoc.org"
    xsi:noNamespaceSchemaLocation="https://docs.phpdoc.org/latest/phpdoc.xsd"
>
    <title>Kawi Resort — Villa Management System</title>

    <paths>
        <output>public/docs</output>
        <cache>.phpdoc/cache</cache>
    </paths>

    <version number="1.0.0">
        <api>
            <source dsn=".">
                <path>app/Models</path>
                <path>app/Services</path>
                <path>app/Livewire</path>
                <path>app/Contracts</path>
            </source>
            <output>api</output>
            <ignore hidden="true">
                <path>app/Http/Middleware/*</path>
            </ignore>
            <extensions>
                <extension>php</extension>
            </extensions>
            <visibility>
                <element>public</element>
                <element>protected</element>
            </visibility>
            <default-package-name>KawiResort</default-package-name>
            <include-source>true</include-source>
        </api>
    </version>

    <template name="default"/>
</phpdocumentor>
